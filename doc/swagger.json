{
  "openapi": "3.0.3",
  "info": {
    "title": "Subscribe API",
    "version": "1.0.0",
    "description": "REST API untuk aplikasi Subscription dengan pembayaran Midtrans. Dokumentasi berisi endpoint user, subscription, dan payment."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Mengecek status server.",
        "responses": {
          "200": {
            "description": "Server is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "uptime": {
                      "type": "number",
                      "example": 12.34
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Get all users",
        "description": "Mengambil daftar user.",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create user",
        "description": "Membuat user baru.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "summary": "Get user by ID",
        "description": "Mengambil user berdasarkan ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "description": "User found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/subscriptions": {
      "get": {
        "summary": "Get all subscriptions",
        "description": "Mengambil daftar subscription.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Subscription"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create subscription",
        "description": "Membuat subscription baru.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriptionCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/subscriptions/{id}": {
      "get": {
        "summary": "Get subscription by ID",
        "description": "Mengambil subscription berdasarkan ID.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/SubscriptionId"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "summary": "Update subscription",
        "description": "Memperbarui data subscription.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/SubscriptionId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriptionUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/payments/create": {
      "post": {
        "summary": "Create payment",
        "description": "Membuat transaksi Midtrans dan menyimpan record payment.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment created and Midtrans transaction returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentCreateResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/payments/notification": {
      "post": {
        "summary": "Midtrans payment notification",
        "description": "Endpoint callback untuk menerima notifikasi status pembayaran dari Midtrans.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MidtransNotificationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification processed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "payment": {
                      "type": "string",
                      "example": "settlement"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Login user",
        "description": "Login dengan email dan password, mengembalikan access token dan refresh token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/refresh": {
      "post": {
        "summary": "Refresh access token",
        "description": "Memperbarui access token menggunakan refresh token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRefreshRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthAccessTokenResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/logout": {
      "post": {
        "summary": "Logout user",
        "description": "Menghapus refresh token dari database.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthLogoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "UserId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "example": 1
        },
        "description": "ID user"
      },
      "SubscriptionId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "example": 1
        },
        "description": "ID subscription"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Resource conflict",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Email sudah digunakan"
          },
          "details": {
            "type": "string",
            "example": "Duplicate entry"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Budi"
          },
          "email": {
            "type": "string",
            "example": "budi@example.com"
          },
          "phone": {
            "type": "string",
            "example": "081234567890"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-15T08:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-15T08:00:00.000Z"
          }
        }
      },
      "UserCreateRequest": {
        "type": "object",
        "required": ["name", "email"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Budi"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "budi@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "pass1234"
          },
          "phone": {
            "type": "string",
            "example": "081234567890"
          }
        }
      },
      "AuthRegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Budi"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "budi@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "secret123"
          },
          "phone": {
            "type": "string",
            "example": "081234567890"
          }
        }
      },
      "AuthLoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "budi@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "secret123"
          }
        }
      },
      "AuthTokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJI..."
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJI..."
          }
        }
      },
      "AuthRefreshRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJI..."
          }
        }
      },
      "AuthAccessTokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJI..."
          }
        }
      },
      "AuthLogoutRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJI..."
          }
        }
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "example": 1
          },
          "planName": {
            "type": "string",
            "example": "Basic Plan"
          },
          "price": {
            "type": "number",
            "format": "double",
            "example": 50000
          },
          "status": {
            "type": "string",
            "example": "pending"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-05-01T00:00:00.000Z"
          },
          "expiredAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-06-01T00:00:00.000Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-15T08:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-15T08:00:00.000Z"
          }
        }
      },
      "SubscriptionCreateRequest": {
        "type": "object",
        "required": ["planName", "price"],
        "properties": {
          "planName": {
            "type": "string",
            "example": "Basic Plan"
          },
          "price": {
            "type": "number",
            "format": "double",
            "example": 50000
          },
          "status": {
            "type": "string",
            "example": "pending"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-05-01T00:00:00.000Z"
          },
          "expiredAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-06-01T00:00:00.000Z"
          }
        }
      },
      "SubscriptionUpdateRequest": {
        "type": "object",
        "properties": {
          "planName": {
            "type": "string",
            "example": "Basic Plan"
          },
          "price": {
            "type": "number",
            "format": "double",
            "example": 75000
          },
          "status": {
            "type": "string",
            "example": "active"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-05-01T00:00:00.000Z"
          },
          "expiredAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-06-01T00:00:00.000Z"
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "subscriptionId": {
            "type": "integer",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "example": 1
          },
          "midtransOrderId": {
            "type": "string",
            "example": "order-123"
          },
          "midtransTransactionId": {
            "type": "string",
            "example": "f2c91c5f-..."
          },
          "grossAmount": {
            "type": "number",
            "format": "double",
            "example": 50000
          },
          "paymentType": {
            "type": "string",
            "example": "midtrans"
          },
          "paymentStatus": {
            "type": "string",
            "example": "pending"
          },
          "paymentUrl": {
            "type": "string",
            "example": "https://app.midtrans.com/snap/v2/vtweb/..."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-15T08:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-15T08:00:00.000Z"
          }
        }
      },
      "PaymentCreateRequest": {
        "type": "object",
        "required": ["orderId", "grossAmount", "subscriptionId"],
        "properties": {
          "orderId": {
            "type": "string",
            "example": "order-123"
          },
          "grossAmount": {
            "type": "number",
            "format": "double",
            "example": 50000
          },
          "subscriptionId": {
            "type": "integer",
            "example": 1
          },
          "customerDetails": {
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string",
                "example": "Budi"
              },
              "email": {
                "type": "string",
                "format": "email",
                "example": "budi@example.com"
              }
            }
          },
          "itemDetails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "price": {
                  "type": "number"
                },
                "quantity": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "paymentType": {
            "type": "string",
            "example": "midtrans"
          }
        }
      },
      "PaymentCreateResponse": {
        "type": "object",
        "properties": {
          "payment": {
            "$ref": "#/components/schemas/Payment"
          },
          "midtrans": {
            "type": "object",
            "description": "Response object from Midtrans Snap API"
          }
        }
      },
      "MidtransNotificationRequest": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string",
            "example": "order-123"
          },
          "transaction_status": {
            "type": "string",
            "example": "settlement"
          },
          "fraud_status": {
            "type": "string",
            "example": "accept"
          },
          "transaction_id": {
            "type": "string",
            "example": "f2c91c5f-..."
          },
          "status_code": {
            "type": "string",
            "example": "200"
          },
          "status_message": {
            "type": "string",
            "example": "Success"
          },
          "payment_type": {
            "type": "string",
            "example": "credit_card"
          },
          "gross_amount": {
            "type": "string",
            "example": "50000.00"
          },
          "signature_key": {
            "type": "string",
            "example": "abcdef1234567890"
          }
        }
      }
    }
  }
}
