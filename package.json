{
  "name": "subscribe",
  "version": "1.0.0",
  "description": "Backend sederhana untuk Express, TypeORM, dan Midtrans.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migration:create": "npx typeorm migration:create ./src/migrations/InitSubscription --dataSource ./data-source.js",
    "migration:run": "npx typeorm migration:run --dataSource ./data-source.js",
    "migration:show": "npx typeorm migration:show --dataSource ./data-source.js",
    "test": "jest --runInBand"
  },
  "keywords": [
    "express",
    "typeorm",
    "midtrans"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "midtrans-client": "^1.0.2",
    "mysql2": "^3.6.0",
    "reflect-metadata": "^0.1.13",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
